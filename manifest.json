{
  "manifest_version": 3,
  "name": "AI Prompt Queue",
  "version": "0.1.0",
  "description": "Let the AI Always Work, Then Check: Seamless Task Queuing for Busy Minds.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "notifications",
    "sidePanel"
  ],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://grok.x.ai/*",
    "https://claude.ai/*"
  ],
  "icons": {
    "16": "images/icon.png",
    "32": "images/icon.png",
    "48": "images/icon.png",
    "128": "images/icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AI Prompt Queue",
    "default_icon": {
      "16": "images/icon.png",
      "24": "images/icon.png",
      "32": "images/icon.png",
      "48": "images/icon.png",
      "128": "images/icon.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  }
} 